{
  "automerge": true,
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "reviewers": ["Automaat"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track pinned nilaway pseudo-version in scripts/run-nilaway.sh",
      "fileMatch": ["^scripts/run-nilaway\\.sh$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+NILAWAY_VERSION=\"(?<currentValue>.+?)\""
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Group the Svelte / Vite / Vitest toolchain",
      "groupName": "svelte toolchain",
      "matchPackageNames": [
        "/^svelte/",
        "/^@sveltejs\\//",
        "/^vite/",
        "/^@vitest\\//"
      ]
    },
    {
      "description": "Group black-box test Python dependencies",
      "groupName": "backend-bb-tests python",
      "matchManagers": ["pep621", "pip_requirements", "poetry"],
      "matchFileNames": [
        "backend-bb-tests/pyproject.toml",
        "backend-bb-tests/uv.lock"
      ]
    }
  ]
}
