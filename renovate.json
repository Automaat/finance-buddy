{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "reviewers": ["Automaat"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track pinned nilaway pseudo-version in scripts/run-nilaway.sh",
      "fileMatch": ["^scripts/run-nilaway\\.sh$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+NILAWAY_VERSION=\"(?<currentValue>.+?)\""
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Group the Svelte / Vite / Vitest toolchain",
      "groupName": "svelte toolchain",
      "matchPackageNames": [
        "/^svelte/",
        "/^@sveltejs\\//",
        "/^vite/",
        "/^@vitest\\//"
      ]
    },
    {
      "description": "Group the FastAPI / Pydantic / SQLAlchemy backend stack",
      "groupName": "fastapi stack",
      "matchPackageNames": [
        "fastapi",
        "starlette",
        "uvicorn",
        "alembic",
        "/^pydantic/",
        "/^sqlalchemy/"
      ]
    }
  ]
}
